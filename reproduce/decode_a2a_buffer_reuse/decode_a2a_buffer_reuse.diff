+    def _get_a2a_recv_buf(self, numel: int, ref_tensor: torch.Tensor) -> torch.Tensor:
+        # Reuse communication receive buffer across iterations to reduce
+        # per-iteration device allocation overhead on the all-to-all path.
+        buf = self._a2a_recv_buf
+        if (buf is None or buf.numel() < numel or buf.dtype != ref_tensor.dtype
+                or buf.device != ref_tensor.device):
+            buf = torch.empty(numel,
+                              dtype=ref_tensor.dtype,
+                              device=ref_tensor.device)
+            self._a2a_recv_buf = buf
+        return buf[:numel]
 
