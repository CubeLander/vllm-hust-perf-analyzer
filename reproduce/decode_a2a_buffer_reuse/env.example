# Copy this file to local.env and adjust it for the target Ascend host.

# Comma-separated logical devices visible to the workload.
TRACELOOM_DEVICES=3,4,5,6

# Model path in the workload environment. In container mode this is the path
# inside TRACELOOM_CONTAINER.
TRACELOOM_MODEL_PATH=/path/to/model

# vLLM-Ascend checkout to patch for the Decode All-to-All Buffer Reuse A/B run.
# Required only for native host execution. In container mode use
# TRACELOOM_CONTAINER_VLLM_ASCEND_DIR below.
TRACELOOM_VLLM_ASCEND_DIR=/path/to/vllm-ascend

# Optional and recommended when the host is only a Docker launcher: use a
# pre-existing Huawei/Ascend container that already contains msprof, npu-smi,
# CANN, vLLM-Ascend, and the workload Python environment. In this mode the host
# only runs docker exec/cp; profiler and workload execution happen in the
# container.
# TRACELOOM_CONTAINER=train8-docker
# TRACELOOM_CONTAINER_VLLM_ASCEND_DIR=/vllm-workspace/vllm-ascend
# TRACELOOM_CONTAINER_WORKDIR=/vllm-workspace/vllm-ascend
# TRACELOOM_REMOTE_ROOT=/tmp/traceloom_decode_a2a_buffer_reuse

# Optional output root. Defaults to traceloom/out/reproduce/decode_a2a_buffer_reuse.
# TRACELOOM_OUT_ROOT=/path/to/traceloom/out/reproduce/decode_a2a_buffer_reuse

# Optional expected Decode All-to-All Buffer Reuse bundle used by run_profile_pair.sh for paper table
# validation context. Defaults to this repository's thesis experiment bundle.
# TRACELOOM_DECODE_A2A_SOURCE_ROOT=/path/to/run_20260507_npu3456

# vLLM workload shape.
TRACELOOM_TP=4
TRACELOOM_PP=1
TRACELOOM_MAX_MODEL_LEN=1024
TRACELOOM_MAX_TOKENS=32
TRACELOOM_BATCH_SIZE=1
TRACELOOM_ROUNDS=1
TRACELOOM_AB_PAIRS=5
TRACELOOM_DTYPE=bfloat16
TRACELOOM_TRUST_REMOTE_CODE=0
TRACELOOM_DISPATCH_MODE=round

# Decode All-to-All Buffer Reuse thesis setting.
HCCL_OP_EXPANSION_MODE=AIV

# vLLM-Ascend worker isolation for stable msprof collection on hosts where
# workers may touch devices before msprof attaches. The integrated TraceLoom
# script defaults to these stable values; override only for debugging.
# TRACELOOM_NARROW_WORKER_VISIBLE_DEVICES=1
# TRACELOOM_WORKER_MULTIPROC_METHOD=spawn

# Optional TraceLoom analysis selection. Defaults analyze every discovered
# device. Set TRACELOOM_ANALYSIS_DEVICES to pin physical device IDs.
# TRACELOOM_ANALYSIS_TOP_DEVICES=0
# TRACELOOM_ANALYSIS_DEVICES=3,4,5,6
# TRACELOOM_ANALYSIS_MAX_MAIN_EVENTS=5000
# TRACELOOM_ANALYSIS_MAX_MACRO_DEFS=32
# TRACELOOM_ANALYSIS_SUMMARY_TOP_LOOPS=12

# Optional extra arguments passed to msprof by run_profile_pair.sh.
# TRACELOOM_MSPROF_ARGS=--sys-hardware-mem=on --sys-cpu-profiling=on
