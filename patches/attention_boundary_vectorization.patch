@@ -0,0 +1,63 @@
+import torch
+
+from vllm_ascend.attention.utils import (
+    AscendCommonAttentionMetadata,
+    AscendPrefillContextParallelMetadata,
+    split_decodes_and_prefills,
+)
+
+
+def _common_metadata(
+    query_lens: list[int],
+    *,
+    max_query_len: int | None = None,
+    query_lens_pcp_full: list[int] | None = None,
+) -> AscendCommonAttentionMetadata:
+    query_lens_tensor = torch.tensor(query_lens, dtype=torch.int64)
+    query_start_loc = torch.empty(len(query_lens) + 1, dtype=torch.int64)
+    query_start_loc[0] = 0
+    torch.cumsum(query_lens_tensor, dim=0, out=query_start_loc[1:])
+
+    pcp_metadata = None
+    if query_lens_pcp_full is not None:
+        pcp_metadata = AscendPrefillContextParallelMetadata(
+            query_lens_pcp_full_cpu=torch.tensor(query_lens_pcp_full, dtype=torch.int64),
+            max_query_len_pcp_full=max(query_lens_pcp_full),
+        )
+
+    return AscendCommonAttentionMetadata(
+        query_start_loc=query_start_loc,
+        query_start_loc_cpu=query_start_loc,
+        num_reqs=len(query_lens),
+        num_actual_tokens=int(query_start_loc[-1]),
+        max_query_len=max(query_lens) if max_query_len is None else max_query_len,
+        prefill_context_parallel_metadata=pcp_metadata,
+    )
+
+
+def test_split_decodes_and_prefills_decode_only():
+    metadata = _common_metadata([1, 1, 1])
+
+    assert split_decodes_and_prefills(metadata) == (3, 0, 3, 0)
+
+
+def test_split_decodes_and_prefills_prefill_only():
+    metadata = _common_metadata([8, 16, 32])
+
+    assert split_decodes_and_prefills(metadata) == (0, 3, 0, 56)
+
+
+def test_split_decodes_and_prefills_mixed_batch():
+    metadata = _common_metadata([1, 1, 4, 8])
+
+    assert split_decodes_and_prefills(metadata) == (2, 2, 2, 12)
+
+
+def test_split_decodes_and_prefills_uses_full_pcp_query_lens():
+    metadata = _common_metadata(
+        [1, 1, 1, 1],
+        max_query_len=1,
+        query_lens_pcp_full=[1, 1, 128, 256],
+    )
+
+    assert split_decodes_and_prefills(metadata) == (2, 2, 2, 2)
